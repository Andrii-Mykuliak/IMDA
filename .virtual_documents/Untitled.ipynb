"""
Graphical abstract for:
"Inter-Model Disagreement in Kepler Exoplanet Classification: A Leakage-Aware Benchmark"
Output: 1328 x 531 px at 150 dpi (Elsevier: 531h x 1328w px)
"""

import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
from matplotlib.patches import FancyBboxPatch, FancyArrowPatch
import numpy as np

# ---------- canvas ----------
DPI = 150
W_IN = 1328 / DPI   # ~8.85 in
H_IN = 531  / DPI   # ~3.54 in

fig = plt.figure(figsize=(W_IN, H_IN), dpi=DPI)
fig.patch.set_facecolor("#0d1b2a")
ax = fig.add_axes([0, 0, 1, 1])
ax.set_xlim(0, 1)
ax.set_ylim(0, 1)
ax.axis("off")

# ---------- palette ----------
C_BG    = "#0d1b2a"
C_PANEL = "#132338"
C_BLUE  = "#4e9af1"
C_GOLD  = "#f5a623"
C_GREEN = "#50c878"
C_RED   = "#e05c5c"
C_TEXT  = "#e8edf3"
C_DIM   = "#8899aa"
C_ARROW = "#4e9af1"

def box(ax, x, y, w, h, color, alpha=1.0, radius=0.015):
    fancy = FancyBboxPatch((x, y), w, h,
                           boxstyle=f"round,pad=0,rounding_size={radius}",
                           linewidth=0, facecolor=color, alpha=alpha,
                           transform=ax.transAxes, zorder=2)
    ax.add_patch(fancy)

def arrow(ax, x0, y0, x1, y1, color=C_ARROW):
    ax.annotate("", xy=(x1, y1), xytext=(x0, y0),
                xycoords="axes fraction", textcoords="axes fraction",
                arrowprops=dict(arrowstyle="->, head_width=0.3, head_length=0.3",
                                color=color, lw=1.5),
                zorder=5)

def label(ax, x, y, txt, size=8, color=C_TEXT, weight="normal", ha="center", va="center"):
    ax.text(x, y, txt, transform=ax.transAxes,
            fontsize=size, color=color, fontweight=weight,
            ha=ha, va=va, zorder=6)

# ============================================================
# TITLE BAR
# ============================================================
box(ax, 0.0, 0.82, 1.0, 0.18, C_PANEL)
label(ax, 0.5, 0.935,
      "Inter-Model Disagreement in Kepler Exoplanet Classification",
      size=10, weight="bold", color=C_BLUE)
label(ax, 0.5, 0.855,
      "A Leakage-Aware Benchmark  ·  Mykuliak & Vovk  ·  Astronomy and Computing",
      size=7, color=C_DIM)

# ============================================================
# COLUMN layout: 4 panels
# x positions
X = [0.01, 0.26, 0.51, 0.735]
W = 0.225
Y0, H0 = 0.04, 0.73   # bottom, height of main panels
MID = Y0 + H0 / 2

# ---------- helper: section header ----------
def sec_header(ax, x, w, title, color):
    box(ax, x, Y0 + H0 - 0.085, w, 0.085, color, alpha=0.85)
    label(ax, x + w/2, Y0 + H0 - 0.04, title, size=8, weight="bold", color="#ffffff")

# ============================================================
# PANEL 1 — Dataset & leakage control
# ============================================================
p = 0
box(ax, X[p], Y0, W, H0, C_PANEL)
sec_header(ax, X[p], W, "① Dataset", C_BLUE)

# KOI catalogue info
label(ax, X[p]+W/2, 0.685, "NASA KOI Cumulative Catalogue", size=7.5, weight="bold")
label(ax, X[p]+W/2, 0.640, "9 564 entries", size=7, color=C_DIM)

# disposition breakdown bars
bar_x = X[p] + 0.025
bw = W - 0.05
# CONFIRMED
box(ax, bar_x, 0.555, bw * 0.362, 0.045, C_GREEN, alpha=0.9)
label(ax, bar_x + bw*0.18, 0.578, "CONFIRMED  2 746", size=6.5, color="#ffffff")
# FALSE POSITIVE
box(ax, bar_x, 0.500, bw * 0.638, 0.045, C_RED, alpha=0.9)
label(ax, bar_x + bw*0.32, 0.523, "FALSE POSITIVE  4 839", size=6.5, color="#ffffff")
# CANDIDATE
box(ax, bar_x, 0.445, bw * 0.207, 0.045, C_GOLD, alpha=0.9)
label(ax, bar_x + bw*0.104, 0.468, "CANDIDATE  1 979", size=6.5, color="#ffffff")

label(ax, X[p]+W/2, 0.405, "12 physical features", size=7, weight="bold", color=C_TEXT)

# leakage exclusion
box(ax, bar_x, 0.340, bw, 0.050, "#1e0a0a", alpha=0.9, radius=0.01)
label(ax, X[p]+W/2, 0.367, "✗  koi_fpflag_*  |  ✗  koi_score", size=6.5, color=C_RED)
label(ax, X[p]+W/2, 0.305, "Leakage-aware design", size=6.5, color=C_DIM)

# group-aware split
box(ax, bar_x, 0.230, bw, 0.055, "#0a1e12", alpha=0.9, radius=0.01)
label(ax, X[p]+W/2, 0.262, "GroupShuffleSplit", size=6.5, weight="bold", color=C_GREEN)
label(ax, X[p]+W/2, 0.242, "by host star  (kepid)", size=6, color=C_DIM)

label(ax, X[p]+W/2, 0.185, "Train: 80%   Test: 20%", size=6.5, color=C_DIM)
label(ax, X[p]+W/2, 0.155, "Stability: 5 random seeds", size=6.5, color=C_DIM)

# ============================================================
# PANEL 2 — 5 Classifiers + performance
# ============================================================
p = 1
box(ax, X[p], Y0, W, H0, C_PANEL)
sec_header(ax, X[p], W, "② Classifiers & Performance", C_BLUE)

models = [
    ("XGBoost",           0.9793, C_GOLD),
    ("Random Forest",     0.9769, C_GOLD),
    ("SVM",               0.9281, C_BLUE),
    ("Logistic Reg.",     0.8971, C_BLUE),
    ("Decision Tree",     0.8826, C_DIM),
]
bar_x2 = X[p] + 0.015
bw2 = W - 0.03
max_auc = 1.0
bar_w_max = bw2 * 0.62
label_x = bar_x2 + bw2 * 0.36

y_start = 0.660
y_step  = 0.095

for i, (name, auc, color) in enumerate(models):
    yb = y_start - i * y_step
    blen = bar_w_max * (auc - 0.85) / 0.15
    box(ax, label_x, yb - 0.018, blen, 0.036, color, alpha=0.75, radius=0.008)
    label(ax, bar_x2 + bw2*0.175, yb, name, size=6.5, ha="center")
    label(ax, label_x + blen + 0.005, yb, f"{auc:.4f}", size=6, color=color, ha="left")

label(ax, X[p]+W/2, 0.195, "ROC AUC", size=6, color=C_DIM)

# DeLong note
box(ax, bar_x2, 0.130, bw2, 0.048, "#111e2e", alpha=0.9, radius=0.01)
label(ax, X[p]+W/2, 0.158, "XGB vs RF: DeLong p > 0.05", size=6.5, color=C_DIM)
label(ax, X[p]+W/2, 0.140, "difference not statistically conclusive", size=6, color=C_DIM)

# VIF note
label(ax, X[p]+W/2, 0.095, "VIF up to 166 (stellar params)", size=6.5, color=C_RED)
label(ax, X[p]+W/2, 0.075, "explains LR underperformance", size=6, color=C_DIM)

# ============================================================
# PANEL 3 — IMDA on 1979 candidates
# ============================================================
p = 2
box(ax, X[p], Y0, W, H0, C_PANEL)
sec_header(ax, X[p], W, "③ IMDA on 1 979 Candidates", C_GOLD)

# voting pie-like bar
bar_x3 = X[p] + 0.018
bw3 = W - 0.036
total = 1979
counts = [("All NO\n31.5%", 624, C_RED),
          ("Grey Zone\n35.0%", 693, C_GOLD),
          ("All YES\n14.1%", 280, C_GREEN),
          ("Majority\n19.4%", 382, C_BLUE)]

label(ax, X[p]+W/2, 0.675, "Voting Distribution", size=7, weight="bold")
yv = 0.590
xv = bar_x3
for name, cnt, color in counts:
    w_frac = bw3 * cnt / total
    box(ax, xv, yv - 0.028, w_frac - 0.003, 0.056, color, alpha=0.85, radius=0.006)
    if w_frac > 0.025:
        label(ax, xv + w_frac/2, yv, name, size=5.5, color="#ffffff")
    xv += w_frac

# pairwise consistency
label(ax, X[p]+W/2, 0.510, "Pairwise Consistency", size=7, weight="bold")

groups = [("Tree-based", "RF · XGB · DT", "81.9–91.3%", C_GOLD),
          ("Linear/Kernel", "LR · SVM", "88.8%", C_BLUE)]
yg = 0.455
for gname, members, pct, color in groups:
    box(ax, bar_x3, yg - 0.028, bw3, 0.050, color, alpha=0.2, radius=0.01)
    box(ax, bar_x3, yg - 0.028, 0.004, 0.050, color, alpha=1.0, radius=0.005)
    label(ax, bar_x3 + 0.01, yg + 0.005, gname, size=6.5, weight="bold", color=color, ha="left")
    label(ax, bar_x3 + 0.01, yg - 0.013, members, size=6, color=C_DIM, ha="left")
    label(ax, X[p] + W - 0.01, yg, pct, size=7, color=color, ha="right", weight="bold")
    yg -= 0.068

label(ax, X[p]+W/2, 0.285, "Cross-group: 59–65%", size=6.5, color=C_DIM)

# grey zone stability
box(ax, bar_x3, 0.195, bw3, 0.068, "#1a1500", alpha=0.9, radius=0.01)
label(ax, X[p]+W/2, 0.235, "Grey Zone: 32–37%", size=7, weight="bold", color=C_GOLD)
label(ax, X[p]+W/2, 0.215, "across thresholds 0.40–0.60", size=6, color=C_DIM)

label(ax, X[p]+W/2, 0.155, "threshold-robust observation", size=6.5, color=C_DIM)

# ============================================================
# PANEL 4 — Behavioural patterns
# ============================================================
p = 3
box(ax, X[p], Y0, W + 0.028, H0, C_PANEL)
sec_header(ax, X[p], W + 0.028, "④ Behavioural Patterns", C_GREEN)

bw4 = W + 0.028 - 0.036
bar_x4 = X[p] + 0.018

# Pattern A
box(ax, bar_x4, 0.530, bw4, 0.178, "#0a1e12", alpha=0.9, radius=0.012)
label(ax, X[p] + (W+0.028)/2, 0.690, "Pattern A — Low-SNR Candidates", size=7, weight="bold", color=C_GREEN)

snr_labels = ["SNR < 10", "Rp < 2 R⊕"]
snr_vals   = [0.502, 0.48]
snr_colors = [C_GOLD, C_BLUE]
for i, (lbl, val, col) in enumerate(zip(snr_labels, snr_vals, snr_colors)):
    yb = 0.640 - i * 0.065
    box(ax, bar_x4 + 0.01, yb - 0.016, bw4 * val * 0.85, 0.030, col, alpha=0.75, radius=0.006)
    label(ax, bar_x4 + 0.01, yb, lbl, size=6, color=C_TEXT, ha="left")
    label(ax, bar_x4 + 0.01 + bw4*val*0.85 + 0.005, yb, f"{val*100:.0f}% grey", size=6, color=col, ha="left")

label(ax, X[p]+(W+0.028)/2, 0.548,
      "Tabular features insufficient to resolve signal", size=6, color=C_DIM)

# Pattern B
box(ax, bar_x4, 0.310, bw4, 0.195, "#1a0e00", alpha=0.9, radius=0.012)
label(ax, X[p]+(W+0.028)/2, 0.480, "Pattern B — Long-Period Candidates", size=7, weight="bold", color=C_GOLD)

period_bins  = ["0–10d", "10–50d", "50–100d", "100–200d", "200–300d", "300+d"]
consensus    = [0.409,   0.305,    0.342,     0.447,      0.681,      0.925]
col_bars     = [C_RED if c < 0.5 else C_GREEN for c in consensus]

bw_bar = (bw4 - 0.02) / len(period_bins) - 0.006
xb = bar_x4 + 0.01
ybase = 0.325
ymax_h = 0.115
for i, (pbin, cons, col) in enumerate(zip(period_bins, consensus, col_bars)):
    bh = ymax_h * cons
    box(ax, xb, ybase, bw_bar, bh, col, alpha=0.8, radius=0.004)
    label(ax, xb + bw_bar/2, ybase - 0.018, pbin, size=4.8, color=C_DIM)
    xb += bw_bar + 0.006

label(ax, X[p]+(W+0.028)/2, 0.465,
      "Full consensus rate by orbital period", size=5.5, color=C_DIM)
label(ax, X[p]+(W+0.028)/2, 0.325,
      "Unanimous rejection ≠ reliability", size=6, color=C_GOLD)
label(ax, X[p]+(W+0.028)/2, 0.308,
      "training data underrepresentation", size=6, color=C_DIM)

# implication
box(ax, bar_x4, 0.075, bw4, 0.205, "#0d1b2a", alpha=0.95, radius=0.012)
label(ax, X[p]+(W+0.028)/2, 0.255,
      "Implication", size=7, weight="bold", color=C_TEXT)
label(ax, X[p]+(W+0.028)/2, 0.225,
      "Low-SNR → light-curve CNN methods", size=6.5, color=C_BLUE)
label(ax, X[p]+(W+0.028)/2, 0.200,
      "Long-period → single-transit pipelines", size=6.5, color=C_BLUE)
label(ax, X[p]+(W+0.028)/2, 0.175,
      "Both → probabilistic validation frameworks", size=6.5, color=C_BLUE)
label(ax, X[p]+(W+0.028)/2, 0.140,
      "Results do not constitute planet validation.", size=6, color=C_DIM)
label(ax, X[p]+(W+0.028)/2, 0.120,
      "Classification of KOI catalogue dispositions only.", size=6, color=C_DIM)
label(ax, X[p]+(W+0.028)/2, 0.092,
      "github.com/Andrii-Mykuliak/IMDA", size=6, color=C_DIM)

# ============================================================
# ARROWS between panels
# ============================================================
for i in range(3):
    xarr = X[i] + W + 0.003
    arrow(ax, xarr, MID, xarr + 0.008, MID)

# ============================================================
# SAVE
# ============================================================
out = "/mnt/user-data/outputs/graphical_abstract.png"
fig.savefig(out, dpi=DPI, bbox_inches="tight", pad_inches=0,
            facecolor=C_BG)
print(f"Saved: {out}")
print(f"Size check: {1328}x{531} px target")




