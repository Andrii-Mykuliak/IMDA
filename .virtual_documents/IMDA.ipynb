    mce   = maximum_calibration_error(y_true, y_prob)
    hl_s, hl_p = hosmer_lemeshow(y_true, y_prob)
    direction = calibration_direction(y_true, y_prob)
    dir_str = f"+{direction:.3f} (under)" if direction > 0 else f"{direction:.3f} (over)"

