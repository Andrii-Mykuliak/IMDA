print("CALIBRATION DIAGNOSTICS — Test Set")
print("=" * 55)
print(f"{'Model':<22} {'Brier':>7} {'ECE':>7} {'rECE':>7} "
      f"{'MCE':>7} {'HL p':>8} {'Direction'}")
